# GIPHY — server-only (used by the Netlify function, never exposed to the client)
GIF_API_GET_RANDOM=https://api.giphy.com/v1/gifs/random?api_key=YOUR_GIPHY_KEY&rating=g&tag=

# GIPHY — client-side (used by the Vite app directly)
VITE_GIF_API_GET_RANDOM=https://api.giphy.com/v1/gifs/random?api_key=YOUR_GIPHY_KEY&rating=g&tag=

# Supabase — safe to expose client-side (protected by RLS)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
