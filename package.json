{
	"name": "gif-day",
	"version": "0.1.0",
	"private": true,
	"license": "MIT",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"start": "vite",
		"build": "tsc -b && vite build",
		"test": "npm run lint && npm run unit && npm run integration",
		"unit": "vitest",
		"lint": "biome check .",
		"format": "biome format --write .",
		"test:coverage": "vitest run --coverage",
		"integration": "start-server-and-test start http://localhost:3000 cy:run",
		"cy:run": "cypress run"
	},
	"dependencies": {
		"date-fns": "^2.29.2",
		"lodash.times": "^4.3.2",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"react-modal2": "^5.0.2"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/react": "^16.3.0",
		"@testing-library/user-event": "^14.6.1",
		"@types/lodash.times": "^4.3.7",
		"@types/node": "^22.15.29",
		"@types/react": "^19.1.6",
		"@types/react-dom": "^19.1.5",
		"@vitejs/plugin-react": "^4.5.0",
		"autoprefixer": "10.4.21",
		"cypress": "^10.6.0",
		"jsdom": "^26.1.0",
		"mockdate": "^3.0.5",
		"postcss": "8.5.4",
		"start-server-and-test": "^1.14.0",
		"tailwindcss": "3.4.1",
		"typescript": "~5.8.3",
		"vite": "^6.3.5",
		"vitest": "^3.1.4"
	},
	"overrides": {
		"react-modal2": {
			"react": "^19.1.0",
			"react-dom": "^19.1.0"
		}
	},
	"packageManager": "pnpm@10.11.0"
}
