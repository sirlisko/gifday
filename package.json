{
	"name": "gif-day",
	"version": "0.1.0",
	"private": true,
	"license": "MIT",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"start": "vite",
		"build": "tsc -b && vite build",
		"test": "npm run lint && npm run unit && npm run integration",
		"unit": "vitest",
		"lint": "biome check .",
		"format": "biome format --write .",
		"test:coverage": "vitest run --coverage",
		"typecheck": "tsc --noEmit",
		"integration": "playwright test",
		"integration:ui": "playwright test --ui",
		"integration:debug": "playwright test --debug"
	},
	"dependencies": {
		"@supabase/supabase-js": "^2.100.0",
		"date-fns": "^2.29.2",
		"lodash.times": "^4.3.2",
		"react": "^19.1.0",
		"react-dom": "^19.1.0"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@netlify/functions": "^5.1.5",
		"@playwright/test": "^1.52.0",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/react": "^16.3.0",
		"@testing-library/user-event": "^14.6.1",
		"@types/lodash.times": "^4.3.9",
		"@types/node": "^22.15.29",
		"@types/react": "^19.1.6",
		"@types/react-dom": "^19.1.5",
		"@vitejs/plugin-react": "^4.5.0",
		"autoprefixer": "10.4.21",
		"jsdom": "^26.1.0",
		"mockdate": "^3.0.5",
		"postcss": "8.5.4",
		"tailwindcss": "3.4.1",
		"typescript": "~5.8.3",
		"vite": "^6.3.5",
		"vitest": "^3.1.4"
	},
	"packageManager": "pnpm@10.11.0"
}
