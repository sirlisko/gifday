		"@testing-library/react": "^13.3.0",
		"@testing-library/user-event": "^14.4.3",
		"@types/jest": "^27.5.2",
		"@types/lodash.times": "^4.3.7",
		"@types/node": "^22.15.29",
		"@types/react": "^19.1.6",
